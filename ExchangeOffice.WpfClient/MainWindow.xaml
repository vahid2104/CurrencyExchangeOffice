
<Window x:Class="ExchangeOffice.WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office" Height="480" Width="720" WindowStartupLocation="CenterScreen">
    <Grid Background="#F3F6FA">
        <Border Width="520" Padding="20" Background="White" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#E6EEF8" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Currency Exchange Office" FontSize="22" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" />
                <TextBlock Text="Securely buy and sell currencies" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,6,0,12" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Login Card -->
                    <Border Grid.Column="0" Padding="12" Background="#FFF" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Login" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock Text="Username" FontSize="12" Foreground="#6B7280" Margin="0,8,0,0" />
                            <TextBox x:Name="TxtLoginUsername" />
                            <TextBlock Text="Password" FontSize="12" Foreground="#6B7280" Margin="0,8,0,0" />
                            <PasswordBox x:Name="PwdLogin" />
                            <Button x:Name="BtnLogin" Click="BtnLogin_Click" Background="#2563EB" Foreground="White" Margin="0,12,0,0">Login</Button>
                        </StackPanel>
                    </Border>

                    <!-- Register Card -->
                    <Border Grid.Column="2" Padding="12" Background="#FFF" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Register" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock Text="Full name" FontSize="12" Foreground="#6B7280" Margin="0,8,0,0" />
                            <TextBox x:Name="TxtRegFullName" />
                            <TextBlock Text="Username" FontSize="12" Foreground="#6B7280" Margin="0,8,0,0" />
                            <TextBox x:Name="TxtRegUsername" />
                            <TextBlock Text="Password" FontSize="12" Foreground="#6B7280" Margin="0,8,0,0" />
                            <PasswordBox x:Name="PwdReg" />
                            <Button x:Name="BtnRegister" Click="BtnRegister_Click" Background="#1E3A8A" Foreground="White" Margin="0,12,0,0">Register</Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock x:Name="TxtAuthStatus" Foreground="Red" Margin="6" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
